---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../../layouts/Base.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import ZipCard from '../../components/ZipCard.astro';
import StatBlock from '../../components/StatBlock.astro';
import AdSenseUnit from '../../components/AdSenseUnit.astro';
import FAQSection from '../../components/FAQSection.astro';
import SponsorBlock from '../../components/SponsorBlock.astro';
import { formatNumber, citySlug } from '../../lib/formatters';
import { cityPageTitle, cityPageDescription } from '../../lib/seo';

export function getStaticPaths() {
  const cityIndex = JSON.parse(
    fs.readFileSync(path.join(process.cwd(), 'data', 'city_index.json'), 'utf-8')
  );
  return Object.entries(cityIndex).map(([key, info]: [string, any]) => {
    const slug = citySlug(info.city, info.state);
    return {
      params: { slug },
      props: { info },
    };
  });
}

const { info } = Astro.props;
const siteUrl = Astro.site?.origin || 'https://zipcodedetails.netlify.app';

const title = cityPageTitle(info.city, info.state);
const stateFull = info.state_full || info.state;
const zipCount = info.zips?.length || 0;
const description = cityPageDescription(info.city, stateFull, zipCount);

const breadcrumbs = [
  { name: 'Home', url: siteUrl },
  { name: stateFull, url: `${siteUrl}/state/${info.state.toLowerCase()}` },
  { name: `${info.city}, ${info.state}`, url: `${siteUrl}/city/${citySlug(info.city, info.state)}` },
];

// Load zip data for this city
const zipsDir = path.join(process.cwd(), 'data', 'zips');
const cityZips: any[] = [];
for (const z of (info.zips || [])) {
  const fp = path.join(zipsDir, `${z}.json`);
  try {
    if (fs.existsSync(fp)) {
      cityZips.push(JSON.parse(fs.readFileSync(fp, 'utf-8')));
    }
  } catch { /* skip */ }
}

// FAQ for city page
const zipsList = zipCount > 0 ? info.zips.slice(0, 10).join(', ') : '';
const faqs = [
  {
    question: `What is the ZIP code for ${info.city}, ${info.state}?`,
    answer: zipCount === 1
      ? `The ZIP code for ${info.city}, ${stateFull} is ${info.zips[0]}.`
      : `${info.city}, ${stateFull} has ${zipCount} ZIP codes: ${zipsList}${zipCount > 10 ? `, and ${zipCount - 10} more` : ''}.`,
  },
  {
    question: `How many ZIP codes does ${info.city}, ${info.state} have?`,
    answer: `${info.city}, ${stateFull} is served by ${zipCount} ZIP code${zipCount !== 1 ? 's' : ''}. All ZIP codes are listed on this page with their location details.`,
  },
  {
    question: `What county is ${info.city}, ${info.state} in?`,
    answer: info.county
      ? `${info.city}, ${stateFull} is located in ${info.county}.`
      : `County information for ${info.city} is not currently available.`,
  },
  {
    question: `What state is ${info.city} in?`,
    answer: `${info.city} is located in the state of ${stateFull} (${info.state}).`,
  },
  {
    question: `Is ${info.city}, ${info.state} a good place to live?`,
    answer: `This site provides ZIP code and geographic data for ${info.city}, ${stateFull}. For information about quality of life, cost of living, schools, and other community details, we recommend visiting local community resources and real estate websites for the ${info.city} area.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Base title={title} description={description} jsonLd={[faqSchema]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <BreadcrumbSchema items={breadcrumbs} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">
        {info.city}, {info.state} ZIP Codes
      </h1>
      <p class="text-slate-500 mt-2">
        All ZIP codes serving <a href={`/state/${info.state.toLowerCase()}`} class="text-primary hover:underline">{info.city}, {stateFull}</a>
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <StatBlock label="ZIP Codes" value={formatNumber(zipCount)} />
      <StatBlock label="County" value={info.county || 'N/A'} />
    </div>

    <AdSenseUnit slot="city-top-leaderboard" format="horizontal" />

    <section class="mt-8">
      <h2 class="text-xl font-semibold text-slate-900 mb-4">
        All {formatNumber(zipCount)} ZIP Codes in {info.city}, {info.state}
      </h2>

      {cityZips.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cityZips.sort((a, b) => a.zip.localeCompare(b.zip)).map((z) => (
            <ZipCard zip={z.zip} city={z.city} state={z.state} county={z.county} />
          ))}
        </div>
      ) : (
        <div class="bg-white rounded-xl border border-slate-200 p-8">
          <p class="text-slate-500 text-sm mb-4">
            Detailed ZIP code data for {info.city} will be available after the full data build.
          </p>
          <div class="flex flex-wrap gap-2">
            {(info.zips || []).map((z: string) => (
              <a href={`/zip/${z}`} class="inline-flex items-center bg-primary/5 text-primary text-sm font-semibold px-3 py-1 rounded-full hover:bg-primary/10 transition-colors">
                {z}
              </a>
            ))}
          </div>
        </div>
      )}
    </section>

    <AdSenseUnit slot="city-bottom-leaderboard" format="horizontal" />

    <SponsorBlock city={info.city} state={info.state} stateFull={stateFull} />

    <FAQSection faqs={faqs} />

    <div class="mt-8 text-center">
      <a
        href={`/state/${info.state.toLowerCase()}`}
        class="inline-flex items-center gap-2 text-primary font-medium text-sm hover:underline"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6" />
        </svg>
        View all ZIP codes in {stateFull}
      </a>
    </div>

    <div class="mt-12 text-center">
      <p class="text-xs text-slate-400">
        Data sourced from <a href="https://www.census.gov/" rel="nofollow noopener" target="_blank" class="text-primary hover:underline">US Census Bureau</a> and <a href="https://postalpro.usps.com/" rel="nofollow noopener" target="_blank" class="text-primary hover:underline">USPS</a>. This site is for informational purposes only.
      </p>
    </div>
  </div>
</Base>
