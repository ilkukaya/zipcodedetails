---
import Base from '../layouts/Base.astro';
import SearchBox from '../components/SearchBox.astro';
import ZipCard from '../components/ZipCard.astro';
import FAQSection from '../components/FAQSection.astro';
import AdSenseUnit from '../components/AdSenseUnit.astro';
import fs from 'node:fs';
import path from 'node:path';
import { citySlug } from '../lib/formatters';

const stateIndex = JSON.parse(
  fs.readFileSync(path.join(process.cwd(), 'data', 'state_index.json'), 'utf-8')
);

const cityIndex = JSON.parse(
  fs.readFileSync(path.join(process.cwd(), 'data', 'city_index.json'), 'utf-8')
);

const popularZips = JSON.parse(
  fs.readFileSync(path.join(process.cwd(), 'data', 'popular_zips.json'), 'utf-8')
);

// Filter out Carrier Annex, PO Box, Station, Branch, Retail etc. from featured
const excludePatterns = /\b(annex|carrier|station|branch|retail|po box|p\.o\. box|drawer|unit|lobby|terminal|airport)\b/i;
const cleanZips = popularZips.filter((z: any) => !excludePatterns.test(z.city || ''));
const featuredZips = cleanZips.slice(0, 12);

const totalZips = Object.values(stateIndex).reduce((sum: number, s: any) => sum + (s.zip_count || 0), 0);
const totalStates = Object.keys(stateIndex).length;

// Build popular cities list from city index (top 20 by zip count)
const allCities = Object.values(cityIndex) as any[];
const popularCities = allCities
  .filter((c: any) => c.city && c.state && (c.zips?.length || 0) > 0)
  .sort((a: any, b: any) => (b.zips?.length || 0) - (a.zips?.length || 0))
  .slice(0, 20);

const title = 'ZIP Code Details — Free US ZIP Code Lookup | ZIPCodeDetails.com';
const description = `Search ${totalZips.toLocaleString()} ZIP codes in the United States. Free location, geographic, and postal data for every US ZIP code area.`;

const faqs = [
  {
    question: 'What is a ZIP code?',
    answer: 'A ZIP code (Zone Improvement Plan code) is a postal code used by the United States Postal Service (USPS). Introduced in 1963, ZIP codes help the USPS efficiently route and deliver mail. The basic format is five digits (e.g., 90210), though an extended ZIP+4 format adds four more digits for more precise locations.',
  },
  {
    question: 'How do I find my ZIP code?',
    answer: 'You can find your ZIP code by using the search box above. Simply type your city name, state, or address, and we will show matching ZIP codes. You can also search by ZIP code number directly to see its associated city and state.',
  },
  {
    question: 'How do I find ZIP codes by city?',
    answer: 'Use the search box to type any city name. We will show you all matching ZIP codes for that city. You can also browse ZIP codes by state or use our city pages to see every ZIP code in a specific city.',
  },
  {
    question: 'What information does a ZIP code contain?',
    answer: 'Each ZIP code is associated with a primary city, state, and county. Through Census Bureau and USPS data, we also provide land area, geographic coordinates, time zone, and metro area (CBSA) for each ZIP code tabulation area.',
  },
  {
    question: 'Are ZIP codes the same as postal codes?',
    answer: 'Yes, in the United States, ZIP codes are the postal code system. The term "postal code" is used internationally, while "ZIP code" is specific to the US. Other countries have their own postal code systems with different formats.',
  },
  {
    question: 'Are ZIP codes the same as ZIP+4?',
    answer: 'No. A standard ZIP code is 5 digits and covers a general geographic area. ZIP+4 codes add four extra digits to pinpoint a specific delivery segment, such as a city block, building, or PO Box group. This site focuses on the standard 5-digit ZIP codes.',
  },
  {
    question: 'How many ZIP codes are in the United States?',
    answer: `There are approximately ${totalZips.toLocaleString()} ZIP code tabulation areas (ZCTAs) in the United States, based on US Census Bureau data. The exact number of active USPS ZIP codes can vary as new codes are added or old ones are retired.`,
  },
  {
    question: 'Is this official USPS data?',
    answer: 'No. This site uses publicly available data from the US Census Bureau Gazetteer files and USPS postal data. For official address validation or mailing purposes, please use USPS.com or an authorized USPS service.',
  },
  {
    question: 'How accurate is this data?',
    answer: 'Our data is sourced from the US Census Bureau Gazetteer files and USPS postal data. Geographic boundaries are based on ZIP Code Tabulation Areas (ZCTAs), which approximate but do not exactly match USPS delivery routes.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ZIPCodeDetails.com',
  url: 'https://zipcodedetails.com',
  description: 'Free US ZIP code lookup with location and geographic data.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://zipcodedetails.com/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ZIPCodeDetails.com',
  url: 'https://zipcodedetails.com',
  logo: 'https://zipcodedetails.com/favicon.svg',
  description: 'Free US ZIP code lookup and reference data.',
};

const stateEntries = Object.entries(stateIndex).sort((a: any, b: any) => a[1].name.localeCompare(b[1].name));
---

<Base title={title} description={description} jsonLd={[faqSchema, websiteSchema, orgSchema]}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-dark via-primary to-blue-600 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-3xl sm:text-5xl font-bold mb-4 leading-tight">
          ZIP Code Details — Free US ZIP Code Lookup
        </h1>
        <p class="text-lg sm:text-xl text-blue-100 mb-8">
          Search ZIP codes, cities, and states across the United States
        </p>
        <SearchBox size="large" />
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3 text-sm text-blue-200">
          <span>Popular:</span>
          {[
            { zip: '90210', label: 'Beverly Hills' },
            { zip: '10001', label: 'New York' },
            { zip: '60601', label: 'Chicago' },
            { zip: '33101', label: 'Miami' },
            { zip: '90001', label: 'Los Angeles' },
          ].map((z) => (
            <a href={`/zip/${z.zip}`} class="bg-white/10 hover:bg-white/20 px-3 py-1 rounded-full transition-colors">
              {z.zip} {z.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-2xl font-black text-primary tabular-nums">{totalZips.toLocaleString()}</p>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mt-1">ZIP Codes</p>
        </div>
        <div>
          <p class="text-2xl font-black text-primary tabular-nums">{totalStates}</p>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mt-1">States & Territories</p>
        </div>
        <div>
          <p class="text-2xl font-black text-primary tabular-nums">3,143</p>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mt-1">Counties</p>
        </div>
        <div>
          <p class="text-2xl font-black text-accent tabular-nums">Free</p>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mt-1">Forever</p>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Featured ZIP Codes -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-slate-900 mb-6">Featured ZIP Codes</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {featuredZips.map((z: any) => (
          <ZipCard zip={z.zip} city={z.city} state={z.state} />
        ))}
      </div>
    </section>

    <AdSenseUnit slot="home-mid-leaderboard" format="horizontal" />

    <!-- How It Works -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-slate-900 mb-6 text-center">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">1. Search</h3>
          <p class="text-sm text-slate-500">Enter a ZIP code, city name, or state to find matching locations instantly.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="9" y1="21" x2="9" y2="9" />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">2. View Details</h3>
          <p class="text-sm text-slate-500">See city, county, state, time zone, and geographic information for any ZIP code.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">3. Use The Data</h3>
          <p class="text-sm text-slate-500">Look up postal codes, plan a move, or explore geographic data for free.</p>
        </div>
      </div>
    </section>

    <!-- Browse by City -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-slate-900 mb-6">Browse ZIP Codes by City</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {popularCities.map((c: any) => (
          <a
            href={`/city/${citySlug(c.city, c.state)}`}
            class="flex items-center justify-between bg-white rounded-lg border border-slate-200 px-4 py-3 hover:border-primary/30 hover:shadow-sm transition-all group no-underline"
          >
            <span class="text-sm font-medium text-slate-700 group-hover:text-primary transition-colors">{c.city}, {c.state}</span>
            <span class="text-xs text-slate-400 tabular-nums">{c.zips?.length || 0}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Browse by State -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-slate-900 mb-6">Browse ZIP Codes by State</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {stateEntries.map(([abbr, info]: [string, any]) => (
          <a
            href={`/state/${abbr.toLowerCase()}`}
            class="flex items-center justify-between bg-white rounded-lg border border-slate-200 px-4 py-3 hover:border-primary/30 hover:shadow-sm transition-all group no-underline"
          >
            <span class="text-sm font-medium text-slate-700 group-hover:text-primary transition-colors">{info.name}</span>
            <span class="text-xs text-slate-400 tabular-nums">{info.zip_count?.toLocaleString()}</span>
          </a>
        ))}
      </div>
    </section>

    <AdSenseUnit slot="home-bottom-leaderboard" format="horizontal" />

    <!-- FAQ -->
    <FAQSection faqs={faqs} />

    <!-- Census Attribution -->
    <div class="mt-12 text-center">
      <p class="text-xs text-slate-400">
        Data sourced from <a href="https://www.census.gov/" rel="nofollow noopener" target="_blank" class="text-primary hover:underline">US Census Bureau</a> and <a href="https://postalpro.usps.com/" rel="nofollow noopener" target="_blank" class="text-primary hover:underline">USPS</a>. This site is for informational purposes only.
      </p>
    </div>
  </div>
</Base>
