---
import Base from '../../layouts/Base.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const title = 'Free ZIP Code API — US ZIP Code Data | ZIPCodeDetails.com';
const description = 'Free JSON API for US ZIP code data. Look up any ZIP code and get city, state, county, coordinates, time zone, and more. No API key required.';

const siteUrl = Astro.site?.origin || 'https://zipcodedetails.netlify.app';
const breadcrumbs = [
  { name: 'Home', url: siteUrl },
  { name: 'API', url: `${siteUrl}/api` },
];
---

<Base title={title} description={description}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <BreadcrumbSchema items={breadcrumbs} />

    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Free ZIP Code API</h1>
      <p class="text-slate-500 text-lg">
        Simple, free JSON API for US ZIP code data. No API key required. No rate limits. CORS enabled.
      </p>
    </div>

    <section class="space-y-8">
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">ZIP Code Lookup</h2>
        <p class="text-slate-500 text-sm mb-4">Get details for any US ZIP code.</p>
        <div class="bg-slate-900 rounded-lg p-4 overflow-x-auto">
          <code class="text-green-400 text-sm font-mono">GET /api/zip/{'{code}'}.json</code>
        </div>
        <p class="text-slate-500 text-sm mt-3">Example:</p>
        <div class="bg-slate-900 rounded-lg p-4 overflow-x-auto">
          <code class="text-blue-400 text-sm font-mono">{siteUrl}/api/zip/90210.json</code>
        </div>
        <details class="mt-4 group">
          <summary class="text-sm font-semibold text-primary cursor-pointer hover:underline">View example response</summary>
          <div class="bg-slate-900 rounded-lg p-4 mt-2 overflow-x-auto">
            <pre class="text-slate-300 text-xs font-mono">{JSON.stringify({
  zip: "90210",
  city: "Beverly Hills",
  state: "CA",
  state_full: "California",
  county: "Los Angeles County",
  timezone: "America/Los_Angeles",
  dst: true,
  lat: 34.0901,
  lng: -118.4065,
  land_area_sqmi: 5.71,
  water_area_sqmi: 0.0,
  zip_type: "Standard",
  cbsa: "Los Angeles-Long Beach-Anaheim, CA",
  cbsa_code: "31080",
  surrounding_zips: ["90069", "90077", "90024", "90046", "90048"]
}, null, 2)}</pre>
          </div>
        </details>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">List All States</h2>
        <p class="text-slate-500 text-sm mb-4">Get a list of all US states and territories with ZIP code counts.</p>
        <div class="bg-slate-900 rounded-lg p-4 overflow-x-auto">
          <code class="text-green-400 text-sm font-mono">GET /api/states.json</code>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">Search Index</h2>
        <p class="text-slate-500 text-sm mb-4">Get the full search index (all ZIP codes with city and state) for client-side search.</p>
        <div class="bg-slate-900 rounded-lg p-4 overflow-x-auto">
          <code class="text-green-400 text-sm font-mono">GET /search_index.json</code>
        </div>
      </div>
    </section>

    <section class="mt-10 bg-gradient-to-br from-primary/5 to-primary/10 rounded-xl border border-primary/20 p-6">
      <h2 class="text-lg font-semibold text-slate-900 mb-3">API Notes</h2>
      <ul class="list-disc list-inside text-sm text-slate-600 space-y-2">
        <li>All endpoints return JSON with CORS headers enabled.</li>
        <li>Data is static and cached. Responses are served from CDN.</li>
        <li>No API key or authentication required.</li>
        <li>Data is sourced from US Census Bureau and USPS. See our <a href="/about" class="text-primary hover:underline">About page</a> for details.</li>
        <li>This is a free service. For heavy use cases, consider hosting your own copy from our <a href="https://github.com/ilkukaya/zipcodedetails" rel="nofollow noopener" target="_blank" class="text-primary hover:underline">open source repository</a>.</li>
      </ul>
    </section>
  </div>
</Base>
