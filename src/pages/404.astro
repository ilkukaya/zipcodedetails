---
import Base from '../layouts/Base.astro';
import SearchBox from '../components/SearchBox.astro';

const title = 'Page Not Found — ZIPCodeDetails.com';
const description = 'The page you are looking for could not be found. Search for a ZIP code, city, or state instead.';
---

<Base title={title} description={description}>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-6xl font-black text-primary mb-4">404</p>
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-3">Page Not Found</h1>
    <p class="text-slate-500 mb-8">
      The page you are looking for does not exist or has been moved.
    </p>

    <div class="mb-10">
      <p class="text-sm text-slate-500 mb-4">Try searching for a ZIP code, city, or state:</p>
      <SearchBox size="large" />
    </div>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-medium text-sm hover:bg-primary-dark transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        Go to Homepage
      </a>
      <a
        href="/search"
        class="inline-flex items-center gap-2 border border-slate-300 text-slate-700 px-5 py-2.5 rounded-lg font-medium text-sm hover:border-primary/30 hover:text-primary transition-all"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        Search ZIP Codes
      </a>
    </div>
  </div>
</Base>
