---
interface Props {
  label: string;
  value: string;
  icon?: string;
  accent?: boolean;
}

const { label, value, icon, accent = false } = Astro.props;
---

<div class={`bg-white rounded-xl shadow-sm border border-slate-200 p-5 relative overflow-hidden ${accent ? 'border-l-4 border-l-accent' : 'border-l-4 border-l-primary'}`}>
  <div class="flex items-start justify-between">
    <div>
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">{label}</p>
      <p class="text-2xl font-black text-slate-900 tabular-nums">{value}</p>
    </div>
    {icon && (
      <div class="text-slate-300" set:html={icon} />
    )}
  </div>
</div>
