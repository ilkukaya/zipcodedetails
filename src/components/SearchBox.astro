---
interface Props {
  size?: 'large' | 'small';
  placeholder?: string;
}

const { size = 'small', placeholder = 'Search by ZIP code, city, or state...' } = Astro.props;
const inputClass = size === 'large'
  ? 'w-full px-6 py-4 text-lg rounded-xl border-2 border-slate-300 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all'
  : 'w-full px-4 py-3 text-sm rounded-lg border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all';
---

<div class="search-box relative w-full max-w-2xl mx-auto">
  <div class="relative">
    <svg class={`absolute ${size === 'large' ? 'left-5 top-5 w-5 h-5' : 'left-3 top-3.5 w-4 h-4'} text-slate-400 pointer-events-none`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8" />
      <line x1="21" y1="21" x2="16.65" y2="16.65" />
    </svg>
    <input
      type="text"
      id="zip-search-input"
      class={`${inputClass} ${size === 'large' ? 'pl-14' : 'pl-10'}`}
      placeholder={placeholder}
      autocomplete="off"
      aria-label="Search ZIP codes"
    />
  </div>
  <div id="search-results" class="absolute z-50 w-full mt-1 bg-white rounded-lg shadow-lg border border-slate-200 hidden max-h-80 overflow-y-auto"></div>
</div>

<script>
  let searchData: Array<{ zip: string; city: string; state: string }> | null = null;

  async function loadSearchData() {
    if (searchData) return searchData;
    try {
      const resp = await fetch('/search_index.json');
      searchData = await resp.json();
    } catch {
      searchData = [];
    }
    return searchData;
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function citySlug(city: string, state: string): string {
    return (
      city
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-') +
      '-' +
      state.toLowerCase()
    );
  }

  const input = document.getElementById('zip-search-input') as HTMLInputElement;
  const results = document.getElementById('search-results') as HTMLDivElement;

  if (input && results) {
    let debounce: ReturnType<typeof setTimeout>;

    input.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(async () => {
        const q = input.value.trim().toLowerCase();
        if (q.length < 2) {
          results.classList.add('hidden');
          return;
        }

        const data = await loadSearchData();
        if (!data) return;

        // Find matching ZIPs
        const zipMatches = data
          .filter(
            (d) =>
              d.zip.startsWith(q) ||
              d.city.toLowerCase().includes(q) ||
              d.state.toLowerCase() === q
          )
          .slice(0, 8);

        // Deduplicate cities for city-level results
        const cityMap = new Map<string, { city: string; state: string; count: number }>();
        for (const d of data) {
          if (d.city.toLowerCase().includes(q) || d.state.toLowerCase() === q) {
            const key = `${d.city}_${d.state}`;
            if (!cityMap.has(key)) {
              cityMap.set(key, { city: d.city, state: d.state, count: 1 });
            } else {
              cityMap.get(key)!.count++;
            }
          }
        }
        const cityMatches = Array.from(cityMap.values())
          .sort((a, b) => b.count - a.count)
          .slice(0, 4);

        // Deduplicate states
        const stateMap = new Map<string, { state: string; count: number }>();
        for (const d of data) {
          if (d.state.toLowerCase().startsWith(q)) {
            if (!stateMap.has(d.state)) {
              stateMap.set(d.state, { state: d.state, count: 1 });
            } else {
              stateMap.get(d.state)!.count++;
            }
          }
        }
        const stateMatches = Array.from(stateMap.values()).slice(0, 3);

        if (zipMatches.length === 0 && cityMatches.length === 0 && stateMatches.length === 0) {
          results.innerHTML = '<div class="p-4 text-sm text-slate-500">No results found. Try a ZIP code, city, or state name.</div>';
        } else {
          let html = '';

          // State results
          if (stateMatches.length > 0 && q.length <= 3) {
            html += '<div class="px-4 py-2 text-xs font-semibold text-slate-400 uppercase tracking-wider bg-slate-50">States</div>';
            for (const s of stateMatches) {
              html += `<a href="/state/${encodeURIComponent(s.state.toLowerCase())}" class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition-colors border-b border-slate-100 no-underline">
                <div>
                  <span class="text-sm font-semibold text-slate-700">${escapeHtml(s.state)}</span>
                  <span class="text-xs text-slate-400 ml-2">${s.count} ZIP codes</span>
                </div>
                <svg class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </a>`;
            }
          }

          // City results
          if (cityMatches.length > 0 && !/^\d/.test(q)) {
            html += '<div class="px-4 py-2 text-xs font-semibold text-slate-400 uppercase tracking-wider bg-slate-50">Cities</div>';
            for (const c of cityMatches) {
              const slug = citySlug(c.city, c.state);
              html += `<a href="/city/${encodeURIComponent(slug)}" class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition-colors border-b border-slate-100 no-underline">
                <div>
                  <span class="text-sm font-semibold text-slate-700">${escapeHtml(c.city)}, ${escapeHtml(c.state)}</span>
                  <span class="text-xs text-slate-400 ml-2">${c.count} ZIP codes</span>
                </div>
                <svg class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </a>`;
            }
          }

          // ZIP results
          if (zipMatches.length > 0) {
            html += '<div class="px-4 py-2 text-xs font-semibold text-slate-400 uppercase tracking-wider bg-slate-50">ZIP Codes</div>';
            for (const m of zipMatches) {
              html += `<a href="/zip/${encodeURIComponent(m.zip)}" class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-0 no-underline">
                <div>
                  <span class="font-semibold text-primary">${escapeHtml(m.zip)}</span>
                  <span class="text-sm text-slate-600 ml-2">${escapeHtml(m.city)}, ${escapeHtml(m.state)}</span>
                </div>
                <svg class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </a>`;
            }
          }

          results.innerHTML = html;
        }
        results.classList.remove('hidden');
      }, 200);
    });

    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        const q = input.value.trim();
        if (/^\d{5}$/.test(q)) {
          window.location.href = `/zip/${q}`;
        }
      }
    });

    document.addEventListener('click', (e) => {
      if (!results.contains(e.target as Node) && e.target !== input) {
        results.classList.add('hidden');
      }
    });
  }
</script>
