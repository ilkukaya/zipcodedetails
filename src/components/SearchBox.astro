---
interface Props {
  size?: 'large' | 'small';
  placeholder?: string;
}

const { size = 'small', placeholder = 'Search by ZIP code, city, or state...' } = Astro.props;
const inputClass = size === 'large'
  ? 'w-full px-6 py-4 text-lg rounded-xl border-2 border-slate-300 focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all'
  : 'w-full px-4 py-3 text-sm rounded-lg border border-slate-300 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all';
---

<div class="search-box relative w-full max-w-2xl mx-auto">
  <div class="relative">
    <svg class={`absolute ${size === 'large' ? 'left-5 top-5 w-5 h-5' : 'left-3 top-3.5 w-4 h-4'} text-slate-400 pointer-events-none`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8" />
      <line x1="21" y1="21" x2="16.65" y2="16.65" />
    </svg>
    <input
      type="text"
      id="zip-search-input"
      class={`${inputClass} ${size === 'large' ? 'pl-14' : 'pl-10'}`}
      placeholder={placeholder}
      autocomplete="off"
      aria-label="Search ZIP codes"
    />
  </div>
  <div id="search-results" class="absolute z-50 w-full mt-1 bg-white rounded-lg shadow-lg border border-slate-200 hidden max-h-80 overflow-y-auto"></div>
</div>

<script>
  let searchData: Array<{ zip: string; city: string; state: string }> | null = null;

  async function loadSearchData() {
    if (searchData) return searchData;
    try {
      const resp = await fetch('/search_index.json');
      searchData = await resp.json();
    } catch {
      searchData = [];
    }
    return searchData;
  }

  const input = document.getElementById('zip-search-input') as HTMLInputElement;
  const results = document.getElementById('search-results') as HTMLDivElement;

  if (input && results) {
    let debounce: ReturnType<typeof setTimeout>;

    input.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(async () => {
        const q = input.value.trim().toLowerCase();
        if (q.length < 2) {
          results.classList.add('hidden');
          return;
        }

        const data = await loadSearchData();
        if (!data) return;

        const matches = data
          .filter(
            (d) =>
              d.zip.startsWith(q) ||
              d.city.toLowerCase().includes(q) ||
              d.state.toLowerCase() === q
          )
          .slice(0, 10);

        if (matches.length === 0) {
          results.innerHTML = '<div class="p-4 text-sm text-slate-500">No results found</div>';
        } else {
          results.innerHTML = matches
            .map(
              (m) =>
                `<a href="/zip/${m.zip}" class="flex items-center justify-between px-4 py-3 hover:bg-slate-50 transition-colors border-b border-slate-100 last:border-0 no-underline">
                  <div>
                    <span class="font-semibold text-primary">${m.zip}</span>
                    <span class="text-sm text-slate-600 ml-2">${m.city}, ${m.state}</span>
                  </div>
                  <svg class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                </a>`
            )
            .join('');
        }
        results.classList.remove('hidden');
      }, 200);
    });

    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        const q = input.value.trim();
        if (/^\d{5}$/.test(q)) {
          window.location.href = `/zip/${q}`;
        }
      }
    });

    document.addEventListener('click', (e) => {
      if (!results.contains(e.target as Node) && e.target !== input) {
        results.classList.add('hidden');
      }
    });
  }
</script>
