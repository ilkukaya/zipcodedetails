---
import ZipCard from './ZipCard.astro';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  zips: string[];
}

const { zips } = Astro.props;

interface ZipInfo {
  zip: string;
  city: string;
  state: string;
  population: number | null;
  median_household_income: number | null;
  county: string;
}

const nearbyData: ZipInfo[] = [];
for (const z of zips) {
  const filePath = path.join(process.cwd(), 'data', 'zips', `${z}.json`);
  try {
    if (fs.existsSync(filePath)) {
      const raw = fs.readFileSync(filePath, 'utf-8');
      const data = JSON.parse(raw);
      nearbyData.push({
        zip: data.zip,
        city: data.city,
        state: data.state,
        population: data.population,
        median_household_income: data.median_household_income,
        county: data.county,
      });
    }
  } catch {
    // Skip if file doesn't exist
  }
}
---

{nearbyData.length > 0 && (
  <section class="mt-10">
    <h2 class="text-xl font-semibold text-slate-900 mb-4">Nearby ZIP Codes</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {nearbyData.map((z) => (
        <ZipCard
          zip={z.zip}
          city={z.city}
          state={z.state}
          population={z.population}
          income={z.median_household_income}
          county={z.county}
        />
      ))}
    </div>
  </section>
)}
