---
interface Props {
  city: string;
  state: string;
  stateFull: string;
}

const { city, state, stateFull } = Astro.props;
---

<section class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border border-blue-100 p-6 mt-8">
  <h2 class="text-lg font-semibold text-slate-900 mb-4">Planning a Move to {city}, {state}?</h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <h3 class="text-sm font-semibold text-slate-800">Moving Services</h3>
      </div>
      <p class="text-xs text-slate-500 mb-3">Compare quotes from top-rated movers in the {city} area.</p>
      <a href={`https://www.google.com/search?q=moving+companies+${encodeURIComponent(city)}+${encodeURIComponent(state)}`} target="_blank" rel="nofollow noopener sponsored" class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline">
        Find Movers
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <h3 class="text-sm font-semibold text-slate-800">Real Estate</h3>
      </div>
      <p class="text-xs text-slate-500 mb-3">Browse homes for sale and rentals in {city}, {stateFull}.</p>
      <a href={`https://www.google.com/search?q=homes+for+sale+${encodeURIComponent(city)}+${encodeURIComponent(state)}`} target="_blank" rel="nofollow noopener sponsored" class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline">
        Search Homes
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
    <div class="bg-white rounded-lg border border-slate-200 p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <h3 class="text-sm font-semibold text-slate-800">Home Insurance</h3>
      </div>
      <p class="text-xs text-slate-500 mb-3">Compare home insurance rates for the {city} area.</p>
      <a href={`https://www.google.com/search?q=home+insurance+${encodeURIComponent(city)}+${encodeURIComponent(state)}`} target="_blank" rel="nofollow noopener sponsored" class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline">
        Get Quotes
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </div>
</section>
